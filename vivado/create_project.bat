REM ============================================================================
REM Vivado 工程创建 - Windows 一键启动
REM 双击此文件即可创建工程并打开 Vivado GUI
REM 前提: Vivado 已安装且在 PATH 中, 或将路径改为实际安装位置
REM ============================================================================
@echo off
cd /d "%~dp0"
echo =============================================
echo  启动 Vivado 并创建工程...
echo =============================================
vivado -source create_project.tcl
pause
