digraph G {
    rankdir=LR;
    bgcolor="white";
    node [shape=box, style="filled,rounded", fontname="Times New Roman", fontsize=12];

    // 定义颜色
    subgraph cluster_core {
        label="Sophon Core";
        style="dashed";
        color="black";
        fontname="Times New Roman";
        fontsize=14;

        ifu [label="IFU\n(Instruction Fetch)", fillcolor="#b3d9ff"];
        id  [label="ID\n(Decode & RegFile)", fillcolor="#b3ffb3"];
        ex  [label="EX\n(Execute & Forward)", fillcolor="#ffcc99"];
        mem [label="MEM\n(Memory Access)", fillcolor="#d9b3ff"];
        wb  [label="WB\n(Write Back)", fillcolor="#ffffb3"];

        csr    [label="CSR & Interrupt\n(csr_regfile, interrupt_controller,\n interrupt_pipeline)", fillcolor="#ffb3b3"];
        hazard [label="Hazard Unit\n(load-use, branch flush)", fillcolor="#ffb3b3"];
        fwd    [label="Forwarding Unit", fillcolor="#ffb3b3"];

        ifu -> id [label="instr / PC"];
        id -> ex;
        ex -> mem;
        mem -> wb;
        wb -> id [label="write-back data", style="dashed", color="gray"];

        ex -> fwd [style="dashed", color="gray"];
        fwd -> ex [label="forward data", style="dashed", color="gray"];
        id -> hazard [style="dashed", color="gray"];
        hazard -> ifu [label="stall / flush", style="dashed", color="gray"];
        hazard -> id;
        hazard -> ex;
        hazard -> mem;
        hazard -> wb;

        ex -> csr [label="CSR instr", style="dashed", color="gray"];
        csr -> ex [label="CSR result", style="dashed", color="gray"];
        csr -> id [style="dashed", color="gray"];
        csr -> ifu [label="interrupt PC", style="dashed", color="red"];
    }

    // 外设
    inst_ram [label="Inst ROM\n(program.hex)", fillcolor="#e6e6e6"];
    data_ram [label="Data RAM\n(unified)", fillcolor="#e6e6e6"];
    bus_arb  [label="Bus Arbiter", fillcolor="#e6e6e6"];
    uart [label="UART", fillcolor="#e6e6e6"];
    gpio [label="GPIO", fillcolor="#e6e6e6"];
    timer [label="Timer", fillcolor="#e6e6e6"];
    spi [label="SPI", fillcolor="#e6e6e6"];
    i2c [label="I2C", fillcolor="#e6e6e6"];

    ifu -> inst_ram [label="PC", style="dashed"];
    inst_ram -> ifu [label="instruction"];

    mem -> bus_arb [label="load/store"];
    bus_arb -> mem [label="read data / ready"];
    bus_arb -> data_ram;
    data_ram -> bus_arb;
    bus_arb -> {uart, gpio, timer, spi, i2c};
    uart -> bus_arb;
    gpio -> bus_arb;
    timer -> bus_arb;
    spi -> bus_arb;
    i2c -> bus_arb;

    // 中断线
    gpio -> csr [label="GPIO intr", color="red"];
    timer -> csr [label="Timer intr", color="red"];
    spi -> csr [label="SPI intr", color="red"];
    i2c -> csr [label="I2C intr", color="red"];
}